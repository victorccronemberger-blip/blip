{
  "$schema": "https://mimo.xiaomi.com/mimocode/config.json",

  // Config de PROJETO (versionada). Lida sempre que o app roda dentro deste
  // repositório, em qualquer OS, independente do MIMOCODE_HOME do modo dev.

  // Nunca auto-atualizar: o updater embutido puxa o MiMoCode upstream original e
  // sobrescreveria este fork (Antigravity/OmniRoute, pentestercode, plugins).
  "autoupdate": false,

  "provider": {
    // Provedor local via LM Studio (Local API Server em http://localhost:1234).
    // Fallback para quando não há API key de provedor na nuvem.
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        // 127.0.0.1 evita problema de resolução IPv6 do "localhost".
        "baseURL": "http://127.0.0.1:1234/v1",
        // LM Studio ignora a chave, mas o SDK exige um valor não-vazio.
        "apiKey": "lm-studio"
      },
      "models": {
        // O ID precisa bater EXATAMENTE com o modelo carregado no LM Studio.
        // Em CADA máquina, confira os IDs em: GET http://127.0.0.1:1234/v1/models
        // e ajuste/adicione aqui conforme o que estiver carregado.
        "qwythos-9b-claude-mythos-5-1m": {
          "name": "Qwythos 9B (local)",
          "tool_call": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    },

    // Zyloo — gateway unificado 100% OpenAI-compatible (GPT, Claude, Gemini,
    // Grok, DeepSeek, Qwen, Llama) atrás de UMA chave e UM endpoint.
    // Mesmo padrão do "zai-coding" do config global do PentesterCode.
    //
    // Antes de usar, defina a chave (formato sk-zy-...) como variável de ambiente:
    //   setx ZYLOO_API_KEY "sk-zy-xxxxxxxx"   (reabra o terminal depois)
    // Pegue/rotacione a chave em: https://zyloo.io/dashboard
    //
    // Os IDs abaixo vieram do catálogo em https://zyloo.io/models (2026-07).
    // A doc da API mostra alguns IDs com hífen (ex.: zyloo/claude-opus-4-7) e a
    // página de preços com ponto (zyloo/claude-opus-4.7). CONFIRA os IDs exatos
    // com a sua chave via:  GET https://api.zyloo.io/v1/models  e ajuste aqui.
    // Modelos com raciocínio estendido também existem no sufixo "-thinking".
    "zyloo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zyloo (gateway unificado)",
      "options": {
        // CLIs agênticos usam a raiz; o SDK openai-compatible acrescenta
        // "/chat/completions", então o baseURL precisa terminar em /v1.
        "baseURL": "https://api.zyloo.io/v1",
        "apiKey": "{env:ZYLOO_API_KEY}"
      },
      "models": {
        // Anthropic (Claude)
        "zyloo/claude-fable-5-1m":   { "name": "Claude Fable 5 (1M) — Zyloo",   "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/claude-fable-5":      { "name": "Claude Fable 5 — Zyloo",        "tool_call": true, "limit": { "context": 200000,  "output": 65536 } },
        "zyloo/claude-4-8":          { "name": "Claude Opus 4.8 (1M) — Zyloo",  "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/claude-opus-4.7":     { "name": "Claude Opus 4.7 (1M) — Zyloo",  "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/claude-opus-4.6":     { "name": "Claude Opus 4.6 (1M) — Zyloo",  "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/claude-opus-4.5":     { "name": "Claude Opus 4.5 — Zyloo",       "tool_call": true, "limit": { "context": 200000,  "output": 65536 } },
        "zyloo/claude-sonnet-4.6":   { "name": "Claude Sonnet 4.6 (1M) — Zyloo","tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/claude-sonnet-4.5":   { "name": "Claude Sonnet 4.5 (1M) — Zyloo","tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/claude-haiku-4.5":    { "name": "Claude Haiku 4.5 — Zyloo",      "tool_call": true, "limit": { "context": 200000,  "output": 32768 } },

        // OpenAI (GPT)
        "zyloo/gpt-5.5-pro":         { "name": "GPT-5.5 Pro (1M) — Zyloo",      "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/gpt-5.5":             { "name": "GPT-5.5 (1M) — Zyloo",          "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/gpt-5.4":             { "name": "GPT-5.4 (1M) — Zyloo",          "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/gpt-5.2":             { "name": "GPT-5.2 (400K) — Zyloo",        "tool_call": true, "limit": { "context": 400000,  "output": 65536 } },
        "zyloo/gpt-5.1":             { "name": "GPT-5.1 (400K) — Zyloo",        "tool_call": true, "limit": { "context": 400000,  "output": 65536 } },
        "zyloo/gpt-4.1":             { "name": "GPT-4.1 (1M) — Zyloo",          "tool_call": true, "limit": { "context": 1048576, "output": 32768 } },
        "zyloo/gpt-4o":              { "name": "GPT-4o (128K) — Zyloo",         "tool_call": true, "limit": { "context": 128000,  "output": 16384 } },

        // Google (Gemini)
        "zyloo/gemini-3.5-flash":    { "name": "Gemini 3.5 Flash (1M) — Zyloo", "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/gemini-3.1-pro":      { "name": "Gemini 3.1 Pro (1M) — Zyloo",   "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/gemini-2.5-pro":      { "name": "Gemini 2.5 Pro (1M) — Zyloo",   "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "zyloo/gemini-2.5-flash":    { "name": "Gemini 2.5 Flash (1M) — Zyloo", "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },

        // xAI (Grok)
        "zyloo/grok-4.3":            { "name": "Grok 4.3 (1M) — Zyloo",         "tool_call": true, "limit": { "context": 1048576, "output": 32768 } },
        "zyloo/grok-4.2":            { "name": "Grok 4.2 (2M) — Zyloo",         "tool_call": true, "limit": { "context": 2097152, "output": 32768 } },
        "zyloo/grok-4.1":            { "name": "Grok 4.1 (1M) — Zyloo",         "tool_call": true, "limit": { "context": 1048576, "output": 32768 } },

        // DeepSeek
        "zyloo/deepseek-v4-flash":   { "name": "DeepSeek V4 Flash (1M) — Zyloo","tool_call": true, "limit": { "context": 1048576, "output": 32768 } },
        "zyloo/deepseek-v3.2":       { "name": "DeepSeek V3.2 (131K) — Zyloo",  "tool_call": true, "limit": { "context": 131072,  "output": 32768 } },

        // Qwen
        "zyloo/qwen-3.6-plus":       { "name": "Qwen 3.6 Plus (1M) — Zyloo",    "tool_call": true, "limit": { "context": 1048576, "output": 32768 } },

        // Meta (Llama)
        "zyloo/llama-4-scout":       { "name": "Llama 4 Scout (10M) — Zyloo",   "tool_call": true, "limit": { "context": 10485760, "output": 32768 } },
        "zyloo/llama-4-maverick":    { "name": "Llama 4 Maverick (1M) — Zyloo", "tool_call": true, "limit": { "context": 1048576,  "output": 32768 } },
        "zyloo/llama-3.3-70b":       { "name": "Llama 3.3 70B (131K) — Zyloo",  "tool_call": true, "limit": { "context": 131072,   "output": 32768 } }
      }
    },

    // Qwen Cloud — Token Plan (pessoal). Alibaba Cloud Model Studio no modo
    // compatível com OpenAI, região internacional ap-southeast-1 (Singapura).
    // Docs: https://docs.qwencloud.com/token-plan/personal/token-plan-personal-overview
    //
    // Só define os METADADOS do provedor (endpoint + catálogo de modelos), SEM
    // apiKey de propósito: assim ele aparece na lista do /connect e você conecta
    // pelo FLUXO NATIVO do app —
    //   /connect  ->  selecionar "Qwen Cloud (Token Plan)"  ->  colar a API key.
    // A chave colada é gravada em auth.json e usada automaticamente. Nada de env.
    //
    // O plano usa um ALLOWLIST de IDs EXATOS (sem inferência de versão); os IDs
    // abaixo vieram da doc do plano (2026-07) e são só os modelos de CHAT/LLM.
    // Contexto/saída não constam na doc: valores conservadores — ajuste se preciso.
    "qwencloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen Cloud (Token Plan)",
      "options": {
        // O SDK openai-compatible acrescenta "/chat/completions"; o baseURL
        // precisa terminar em /compatible-mode/v1 (endpoint fornecido).
        "baseURL": "https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1"
      },
      "models": {
        // Limites conforme os model cards da Qwen (2026-07). qwen3.7-plus e
        // qwen3.6-flash aceitam imagem (flash tb vídeo); qwen3.8-max-preview visão.
        // Onde a saída máx. não é publicada, usei um valor seguro.
        "qwen3.8-max-preview": { "name": "Qwen3.8 Max (preview)", "tool_call": true, "limit": { "context": 983616,  "output": 131072 } },
        "qwen3.7-max":         { "name": "Qwen3.7 Max",           "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "qwen3.7-plus":        { "name": "Qwen3.7 Plus",          "tool_call": true, "limit": { "context": 1048576, "output": 65536 } },
        "qwen3.6-flash":       { "name": "Qwen3.6 Flash",         "tool_call": true, "limit": { "context": 262144,  "output": 32768 } },
        "glm-5.2":             { "name": "GLM-5.2",               "tool_call": true, "limit": { "context": 200000,  "output": 32768 } },
        "deepseek-v4-pro":     { "name": "DeepSeek V4 Pro",       "tool_call": true, "limit": { "context": 1048576, "output": 65536 } }
      }
    },

    // OmniRoute — free local AI gateway (github.com/diegosouzapw/OmniRoute): one
    // OpenAI-compatible endpoint fronting 278+ providers / 500+ models. Run the
    // gateway yourself on port 20128 (it's a standalone app), then /connect ->
    // "OmniRoute (local AI gateway)" -> paste the dashboard key. SEM apiKey aqui
    // (fluxo nativo do /connect). IDs = aliases de auto-routing estáveis; fixe um
    // modelo com "<prefixo>/<modelo>" e confira os IDs vivos em .../v1/models.
    "omniroute": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OmniRoute (local AI gateway)",
      "options": {
        "baseURL": "http://localhost:20128/v1"
      },
      "models": {
        "auto/best-coding": { "name": "OmniRoute Auto · Best Coding", "tool_call": true, "limit": { "context": 200000, "output": 32768 } },
        "auto/coding":  { "name": "OmniRoute Auto · Coding",     "tool_call": true, "limit": { "context": 200000, "output": 32768 } },
        "auto/smart":   { "name": "OmniRoute Auto · Smart",      "tool_call": true, "limit": { "context": 200000, "output": 32768 } },
        "auto/fast":    { "name": "OmniRoute Auto · Fast",       "tool_call": true, "limit": { "context": 200000, "output": 32768 } },
        "auto/cheap":   { "name": "OmniRoute Auto · Cheap",      "tool_call": true, "limit": { "context": 200000, "output": 32768 } },
        "auto/offline": { "name": "OmniRoute Auto · Offline",    "tool_call": true, "limit": { "context": 200000, "output": 32768 } }
      }
    }
  }
}
